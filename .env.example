# Dune Analytics API Key
# Get your free API key at: https://dune.com/settings/api
DUNE_API_KEY=your_dune_api_key

# Optional: dedicated Dune query ID for admin historical backfills.
# The query must accept window_start and window_end parameters.
DUNE_BACKFILL_QUERY_ID=

# Optional: enables server-side force refresh for trusted admin calls only.
# Set to a long random secret and send it as the x-admin-refresh-token request header.
# Leave blank to disable force refresh. Never expose this to the browser.
ADMIN_REFRESH_TOKEN=
